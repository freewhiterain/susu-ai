# =============================================================
# 小苏 AI 助手 · 环境变量配置模板
# 复制此文件为 .env，填入真实值，.env 不能提交到 git
# =============================================================


# -------------------------------------------------------------
# 对话模型（LLM）
# LLM_PROVIDER: claude | openai
# 选 openai 时也支持任何 OpenAI 兼容的第三方代理
# -------------------------------------------------------------
LLM_PROVIDER=openai

# OpenAI / 兼容代理
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1   # 换代理只改这里，例如 https://ai-gw.juanji.site
OPENAI_MODEL=gpt-4o                          # 换模型只改这里，例如 gpt-5.4 / gpt-4o-mini

# Anthropic Claude（LLM_PROVIDER=claude 时填）
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_BASE_URL=https://api.anthropic.com # 有代理时改这里
ANTHROPIC_MODEL=claude-sonnet-4-6


# -------------------------------------------------------------
# 向量化模型（Embedding）
# EMBEDDING_PROVIDER: openai | voyage | local
# 与对话模型解耦，可以独立切换
# -------------------------------------------------------------
EMBEDDING_PROVIDER=openai

# OpenAI Embedding（EMBEDDING_PROVIDER=openai 时）
# 默认复用 OPENAI_API_KEY 和 OPENAI_BASE_URL，无需重复填写
# 如果 Embedding 要走不同的 key / 代理，在这里单独覆盖：
OPENAI_EMBEDDING_API_KEY=    # 留空则自动使用 OPENAI_API_KEY
OPENAI_EMBEDDING_BASE_URL=   # 留空则自动使用 OPENAI_BASE_URL
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Voyage AI（EMBEDDING_PROVIDER=voyage 时，Anthropic 官方推荐搭 Claude 使用）
VOYAGE_API_KEY=your-voyage-api-key-here
VOYAGE_EMBEDDING_MODEL=voyage-3

# 本地模型（EMBEDDING_PROVIDER=local 时，无需任何 Key）
LOCAL_EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2


# -------------------------------------------------------------
# Token 成本计算（走配置，切模型时只改这两行）
# 单位：美元 / 百万 token
# 参考：claude-sonnet-4-6 → 3.0 / 15.0
#        gpt-4o           → 2.5 / 10.0
#        gpt-4o-mini      → 0.15 / 0.6
# -------------------------------------------------------------
INPUT_PRICE_PER_M=2.5
OUTPUT_PRICE_PER_M=10.0


# -------------------------------------------------------------
# 数据库
# -------------------------------------------------------------
DATABASE_URL=sqlite:///./data/xiaosu.db
CHROMA_PERSIST_PATH=./data/chroma


# -------------------------------------------------------------
# Redis（多轮对话上下文缓存）
# -------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
REDIS_SESSION_TTL=86400   # 会话保留时长，单位秒，默认 1 天


# -------------------------------------------------------------
# IM 集成 - 飞书
# 开发者后台：https://open.feishu.cn/app
# -------------------------------------------------------------
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=your-feishu-app-secret
FEISHU_VERIFICATION_TOKEN=your-verification-token
FEISHU_ENCRYPT_KEY=your-encrypt-key   # 没开启加密可留空


# -------------------------------------------------------------
# IM 集成 - 钉钉（加分项，不做可留空）
# 开发者后台：https://open.dingtalk.com/
# -------------------------------------------------------------
DINGTALK_APP_KEY=your-dingtalk-app-key
DINGTALK_APP_SECRET=your-dingtalk-app-secret
DINGTALK_ROBOT_CODE=your-robot-code


# -------------------------------------------------------------
# Mock 内部 API
# -------------------------------------------------------------
MOCK_API_BASE_URL=http://localhost:8001
MOCK_API_TIMEOUT=10   # 请求超时秒数


# -------------------------------------------------------------
# Langfuse 可观测性（加分项，不做可留空）
# 免费云端：https://cloud.langfuse.com
# -------------------------------------------------------------
LANGFUSE_ENABLED=false   # 改为 true 开启链路追踪
LANGFUSE_SECRET_KEY=sk-lf-your-secret-key
LANGFUSE_PUBLIC_KEY=pk-lf-your-public-key
LANGFUSE_HOST=https://cloud.langfuse.com


# -------------------------------------------------------------
# 应用通用
# -------------------------------------------------------------
LOG_LEVEL=INFO                        # DEBUG | INFO | WARNING | ERROR
LOG_DIR=./logs
CORS_ORIGINS=http://localhost:3000    # 多个用逗号分隔

# API 重试策略（tenacity）
LLM_RETRY_MAX_ATTEMPTS=3
LLM_RETRY_MIN_WAIT=2    # 最小等待秒数
LLM_RETRY_MAX_WAIT=30   # 最大等待秒数
